{
  "include": ["src"],
  "compilerOptions": {
    "composite": true,
    "declaration": true,
    "declarationMap": true,
    "exactOptionalPropertyTypes": true,
    "module": "nodenext",
    "outDir": "dist",
    "rootDir": "src",
    "sourceMap": true,
    "target": "esnext",
    "lib": ["esnext"],
    "types": ["node"]
  }
}
